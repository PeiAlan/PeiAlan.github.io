        &lt;h1 id=&quot;SpringBoot中普通类无法注入service的解决方案&quot;&gt;&lt;a href=&quot;#SpringBoot中普通类无法注入service的解决方案&quot; class=&quot;headerlink&quot; title=&quot;SpringBoot中普通类无法注入service的解决方案&quot;&gt;
      
    
